# Required
DATABASE_URL=postgres://user:pass@host:5432/switchyard_go
LOGISTICS_BASE_URL=https://localhost:7001
INVENTORY_BASE_URL=https://localhost:7000

# Auth0 M2M — event handler holds the sole token (see ARCHITECTURE.md §3)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=your-api-audience

# HOS configuration
HOS_WARNING_THRESHOLD_HOURS=2.0
DEADHEAD_WINDOW_HOURS=4
DEADHEAD_SEARCH_WINDOW_HOURS=2
LOADING_AGE_THRESHOLD_HOURS=4
DEFAULT_CYCLE_LABEL=60h/7d

# Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@switchyard.com
SMTP_PASS=your-smtp-password
DISPATCH_EMAIL=dispatch@switchyard.com

# Optional
PORT=8080
LOG_LEVEL=info
WAREHOUSE_IDS=WH001,WH002,WH003,WH004,WH005,WH006,WH007,WH008,WH009
